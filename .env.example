# =============================================================================
# AI Advisor Appointment Scheduler — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git. .env is already in .gitignore.
# For Streamlit Cloud deployment, paste these into the Secrets Manager as TOML.
# =============================================================================


# -----------------------------------------------------------------------------
# LLM PROVIDERS
# Primary: Groq (llama-3.1-70b-versatile) — fastest free-tier inference
# Fallback: Anthropic Claude (claude-haiku-4-5) — structured JSON reliability
# -----------------------------------------------------------------------------

GROQ_API_KEY=gsk_REPLACE_WITH_YOUR_GROQ_API_KEY
# Get from: https://console.groq.com → API Keys

ANTHROPIC_API_KEY=sk-ant-REPLACE_WITH_YOUR_ANTHROPIC_API_KEY
# Get from: https://console.anthropic.com → API Keys

# LLM model overrides (optional — defaults used if not set)
GROQ_MODEL=llama-3.1-70b-versatile
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# LLM request timeout in seconds (default: 3)
LLM_TIMEOUT_SECONDS=3


# -----------------------------------------------------------------------------
# SPEECH — STT (Speech-to-Text)
# Primary: Google Cloud Speech-to-Text v2
# Fallback: Deepgram Nova-2
# -----------------------------------------------------------------------------

# Google STT uses the same service account as Google Calendar/Sheets (below).
# No separate key needed if GOOGLE_SERVICE_ACCOUNT_PATH is set.

DEEPGRAM_API_KEY=REPLACE_WITH_YOUR_DEEPGRAM_API_KEY
# Get from: https://console.deepgram.com → API Keys
# Used as fallback when Google STT times out (>3s)

# STT confidence threshold — below this triggers re-prompt (default: 0.7)
STT_CONFIDENCE_THRESHOLD=0.7

# STT silence timeout in seconds before treating as end-of-turn (default: 3)
STT_SILENCE_TIMEOUT_SECONDS=3


# -----------------------------------------------------------------------------
# SPEECH — TTS (Text-to-Speech)
# Primary: Google Cloud Text-to-Speech Neural2
# Fallback: pyttsx3 (local, zero-cost)
# -----------------------------------------------------------------------------

# Google TTS uses the same service account as below — no separate key needed.

# Voice name for Google TTS (default: en-IN-Neural2-A — Indian English, female)
TTS_VOICE_NAME=en-IN-Neural2-A

# TTS cache directory (relative to project root)
TTS_CACHE_DIR=data/tts_cache

# TTS cache TTL in days (default: 7)
TTS_CACHE_TTL_DAYS=7


# -----------------------------------------------------------------------------
# GOOGLE CLOUD — Service Account
# Used for: Calendar API, Sheets API, Speech-to-Text, Text-to-Speech
# One service account covers all Google services.
# -----------------------------------------------------------------------------

# LOCAL DEVELOPMENT: path to the downloaded JSON key file
GOOGLE_SERVICE_ACCOUNT_PATH=config/service_account.json
# How to create:
#   1. Go to console.cloud.google.com → IAM & Admin → Service Accounts
#   2. Create service account, download JSON key
#   3. Save as config/service_account.json (this file is in .gitignore)
#   4. Enable APIs: Calendar, Sheets, Gmail, Speech-to-Text, Text-to-Speech

# CLOUD DEPLOYMENT (Streamlit Cloud / Docker): paste the full JSON content here.
# Leave blank for local development (GOOGLE_SERVICE_ACCOUNT_PATH is used instead).
GOOGLE_SERVICE_ACCOUNT_JSON=
# Example value: {"type":"service_account","project_id":"...","private_key_id":"...",...}


# -----------------------------------------------------------------------------
# GOOGLE CALENDAR
# -----------------------------------------------------------------------------

GOOGLE_CALENDAR_ID=primary
# Use "primary" for the service account's default calendar, OR
# paste the specific Calendar ID from Google Calendar → Settings → Calendar ID
# The service account email must be shared as "Make changes to events" on this calendar.

# Duration of each advisor slot in minutes (default: 30)
CALENDAR_SLOT_DURATION_MINUTES=30

# Tentative hold expiry in hours — how long a TENTATIVE hold stays before auto-cancel (default: 48)
CALENDAR_HOLD_EXPIRY_HOURS=48


# -----------------------------------------------------------------------------
# GOOGLE SHEETS
# -----------------------------------------------------------------------------

GOOGLE_SHEET_ID=REPLACE_WITH_YOUR_SPREADSHEET_ID
# The spreadsheet ID is the long string in the Google Sheets URL:
# https://docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit
# The service account email must be added as Editor on this sheet.

GOOGLE_SHEET_TAB_NAME=Advisor Pre-Bookings
# Name of the worksheet tab where booking records are appended.
# Create this tab manually before first run, with these headers in row 1:
# booking_code | topic_key | topic_label | slot_start_ist | slot_end_ist |
# advisor_id | status | calendar_event_id | email_draft_id | created_at_ist | call_id


# -----------------------------------------------------------------------------
# GMAIL — Email Draft Creation
# IMPORTANT: This uses an App Password, NOT your main Gmail password.
# Drafts are created but NOT sent — advisor must approve and send manually.
# -----------------------------------------------------------------------------

GMAIL_ADDRESS=your-gmail-address@gmail.com
# The Gmail account used to create drafts. Must be the same account whose
# App Password is used below.

GMAIL_APP_PASSWORD=REPLACE_WITH_16_CHAR_APP_PASSWORD
# How to create a Gmail App Password:
#   1. Enable 2-Step Verification on your Google account
#   2. Go to myaccount.google.com → Security → App Passwords
#   3. Select "Mail" and your device → Generate
#   4. Copy the 16-character password (no spaces) here

GMAIL_SMTP_HOST=smtp.gmail.com
GMAIL_SMTP_PORT=587

ADVISOR_EMAIL=advisor@yourcompany.com
# Recipient of all booking approval email drafts.
# This is baked into the draft To: field; advisor approves and sends.

ADVISOR_NAME=Financial Advisor
# Used in email draft salutation


# -----------------------------------------------------------------------------
# SECURITY — Secure URL Signing
# Used to generate tamper-proof, time-limited booking links.
# -----------------------------------------------------------------------------

SECURE_URL_SECRET=REPLACE_WITH_RANDOM_32_CHAR_STRING_minimum
# CRITICAL: Change this before any deployment. Use a cryptographically random string.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"

SECURE_URL_DOMAIN=https://your-app-domain.com
# Base domain for secure booking links. Locally: http://localhost:8501
# In production: your actual deployed domain.

# Secure URL token TTL in seconds (default: 86400 = 24 hours)
SECURE_URL_TTL_SECONDS=86400


# -----------------------------------------------------------------------------
# SESSION MANAGEMENT
# Dev: in-process dict. Production: Redis.
# -----------------------------------------------------------------------------

# Session TTL in seconds (default: 1800 = 30 minutes)
SESSION_TTL_SECONDS=1800

REDIS_URL=redis://localhost:6379/0
# Only used when ENVIRONMENT=production or SESSION_BACKEND=redis
# Docker Compose default: redis://redis:6379/0


# -----------------------------------------------------------------------------
# VECTOR DATABASE — ChromaDB (RAG Pipeline)
# -----------------------------------------------------------------------------

CHROMA_DB_PATH=data/chroma_db
# Path where ChromaDB persists embeddings to disk.

CHROMA_COLLECTION_NAME=advisor_faq
# Name of the ChromaDB collection for FAQ chunks.

# Number of RAG chunks to retrieve per query (default: 3)
RAG_TOP_K=3

# Embedding model for ChromaDB (default: all-MiniLM-L6-v2, runs locally)
EMBEDDING_MODEL=all-MiniLM-L6-v2


# -----------------------------------------------------------------------------
# BOOKING LOGIC
# -----------------------------------------------------------------------------

MOCK_CALENDAR_PATH=data/mock_calendar.json
# Path to the mock calendar JSON file (used in dev/demo; replace with
# Google Calendar free/busy API call in production).

ADVISOR_ID=ADV-001
# Internal advisor identifier written into booking records.

# Maximum number of re-prompts per slot before graceful error (default: 3)
MAX_REPROMPTS=3

# Maximum number of turns per call before force-ending (default: 20)
MAX_TURNS_PER_CALL=20


# -----------------------------------------------------------------------------
# LOGGING & OBSERVABILITY
# -----------------------------------------------------------------------------

LOG_LEVEL=INFO
# Options: DEBUG | INFO | WARNING | ERROR

VOICE_AUDIT_LOG_PATH=data/logs/voice_audit_log.jsonl
# Append-only JSONL file for all call events. Retain for 7 years (regulatory).

MCP_OPS_LOG_PATH=data/logs/mcp_ops_log.jsonl
# Append-only JSONL file for all MCP tool invocations and results.

# Set to true to also print structured logs to stdout (useful in Docker)
LOG_TO_STDOUT=true


# -----------------------------------------------------------------------------
# APPLICATION
# -----------------------------------------------------------------------------

ENVIRONMENT=development
# Options: development | production
# Controls: session backend (dict vs Redis), error verbosity, caching behaviour.

APP_HOST=0.0.0.0
APP_PORT=8000
# FastAPI backend host and port.

STREAMLIT_PORT=8501
# Port for Streamlit demo/testing UI.

# Company name used in agent greeting and email templates
COMPANY_NAME=YourCompany

# Run integration tests against real APIs (default: false)
# Set to true only in CI with real credentials available.
RUN_INTEGRATION=false
